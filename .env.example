# Copy to .env for local testing only. In production these are GitHub Actions
# encrypted secrets — never commit a real .env file.

# Helius RPC API key (https://helius.dev)
HELIUS_API_KEY=

# Base58-encoded Solana private keys — one per trading wallet.
# W9 = main sniper (loosened 0.55 entry gate, most capital)
SOLANA_PRIVATE_KEY_08=
# W8 = secondary sniper (strict 0.70 entry gate)
SOLANA_PRIVATE_KEY_07=

# Optional: set to "true" to log actions without ever sending real transactions
DRY_RUN=false
